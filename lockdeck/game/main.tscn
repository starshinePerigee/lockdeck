offset_right = 1260.0
offset_bottom = 275.0
theme_override_font_sizes/font_size = 16
text = "These are the pins. Your goal is to find the \"key\", where each pin is positioned so you can open the lock. 

Each pin is made up of 9 segments. The \"base\", as well as most segments, do nothing. One segment is the key... and one segment will break the pick you used to activate it!

If you land on the last segment, the pin will reset cleanly. Otherwise, if you overshoot, you will also break your pick."
autowrap_mode = 2

